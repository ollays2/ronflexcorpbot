# Token du bot Discord (onglet "Bot" de ton application Discord)
DISCORD_TOKEN=

# Application ID de ton application Discord (onglet "General Information")
DISCORD_CLIENT_ID=

# ID du serveur Discord sur lequel déployer les commandes slash
DISCORD_GUILD_ID=

# IDs des rôles Discord autorisés à utiliser les commandes du bot (séparés par des virgules).
# Laisser vide = tout le monde peut utiliser les commandes (déconseillé).
ALLOWED_ROLE_IDS=

# Token GitHub (fine-grained, restreint au dépôt ci-dessous, permission "Contents: Read and write")
GITHUB_TOKEN=

# Propriétaire et nom du dépôt GitHub à mettre à jour (ex. le site RonflexCorp)
GITHUB_OWNER=ollays2
GITHUB_REPO=ronflexcorp

# Branche à écrire (déclenche le redéploiement du site sur cette branche)
GITHUB_BRANCH=main
