# Discord — onglet "Bot" de ton application (discord.com/developers/applications)
DISCORD_TOKEN=

# Discord — onglet "General Information" de ton application
DISCORD_CLIENT_ID=

# ID de ton serveur Discord (mode développeur activé → clic droit sur le serveur → Copier l'ID)
DISCORD_GUILD_ID=

# IDs des rôles autorisés à utiliser les commandes d'administration, séparés par des virgules
# Laisser vide = pas de restriction (déconseillé)
ALLOWED_ROLE_IDS=

# GitHub — token créé sur github.com/settings/tokens?type=beta
# Restreint au dépôt concerné, permission "Contents: Read and write"
GITHUB_TOKEN=

# Propriétaire (utilisateur ou organisation) du dépôt qui contient pokemon.json, team.json, etc.
GITHUB_OWNER=

# Nom du dépôt qui contient pokemon.json, team.json, etc.
GITHUB_REPO=

# Branche sur laquelle committer (doit correspondre à la branche réellement déployée par Vercel)
# Par défaut : main
GITHUB_BRANCH=main
